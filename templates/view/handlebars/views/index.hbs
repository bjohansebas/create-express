<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}}</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <main>
      <h1 class="logo">
        <a href="https://expressjs.com" target="_blank" rel="noopener noreferrer">
          <picture>
            <source srcset="/images/logo-express-white.svg" media="(prefers-color-scheme: dark)" />
            <img src="/images/logo-express-black.svg" alt="Express" />
          </picture>
        </a>
      </h1>
      <p class="tagline">Fast, unopinionated, minimalist web framework for Node.js</p>
      <a class="button" href="https://expressjs.com/en/5x/api" target="_blank" rel="noopener noreferrer">Read the Express 5 docs &rarr;</a>
    </main>
  </body>
</html>
